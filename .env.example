# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_DEBUG=True

# Database
DATABASE_URL=postgres://investo:investo@localhost:5432/investo

# Redis
REDIS_URL=redis://localhost:6379/0

# Channels (uses same Redis, different DB)
CHANNEL_LAYER_URL=redis://localhost:6379/1

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=investo-media
MINIO_USE_SSL=False

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# Email (development: console)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@investo.com

# Celery
CELERY_BROKER_URL=redis://:redispass@localhost:6379/0

# Sentry (optional)
SENTRY_DSN=
